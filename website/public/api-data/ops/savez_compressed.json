        "title": "See also"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "The "
              },
              {
                "kind": "code",
                "text": ".npz"
              },
              {
                "kind": "text",
                "text": " file format is a zipped archive of files named after the\nvariables they contain.  The archive is compressed with\n"
              },
              {
                "kind": "code",
                "text": "zipfile.ZIP_DEFLATED"
              },
              {
                "kind": "text",
                "text": " and each file in the archive contains one variable\nin "
              },
              {
                "kind": "code",
                "text": ".npy"
              },
              {
                "kind": "text",
                "text": " format. For a description of the "
              },
              {
                "kind": "code",
                "text": ".npy"
              },
              {
                "kind": "text",
                "text": " format, see\n"
              },
              {
                "display_text": "flops.lib.format",
                "explicit_title": false,
                "external_url": "",
                "href": "",
                "kind": "role_reference",
                "original_target": "flops.lib.format",
                "role": "py:mod",
                "suppress_link": false,
                "target": "lib.format",
                "unresolved": true
              },
              {
                "kind": "text",
                "text": "."
              }
            ],
            "type": "paragraph"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "When opening the saved "
              },
              {
                "kind": "code",
                "text": ".npz"
              },
              {
                "kind": "text",
                "text": " file with "
              },
              {
                "external_url": "",
                "href": "/docs/api/numpy/load/",
                "kind": "link",
                "target": "load",
                "text": "load"
              },
              {
                "kind": "text",
                "text": " a "
              },
              {
                "kind": "code",
                "text": "~lib.npyio.NpzFile"
              },
              {
                "kind": "text",
                "text": "\nobject is returned. This is a dictionary-like object which can be queried\nfor its list of arrays (with the "
              },
              {
                "kind": "code",
                "text": ".files"
              },
              {
                "kind": "text",
                "text": " attribute), and for the arrays\nthemselves."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Notes"
