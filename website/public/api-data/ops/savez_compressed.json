        "blocks": [
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import flopscope.numpy as fnp"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "test_array = flops.random.rand(3, 2)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "test_vector = flops.random.rand(4)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "flops.savez_compressed('/tmp/123', a=test_array, b=test_vector)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "loaded = flops.load('/tmp/123.npz')"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "print(flops.array_equal(test_array, loaded['a']))"
              },
              {
                "kind": "output",
                "text": "True"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "print(flops.array_equal(test_vector, loaded['b']))"
              },
              {
                "kind": "output",
                "text": "True"
              }
            ],
            "type": "doctest_block"
          }
        ],
