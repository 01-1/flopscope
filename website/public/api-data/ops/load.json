      {
        "blocks": [
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import flopscope.numpy as fnp"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Store data to disk, and load it again:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "flops.save('/tmp/123', flops.array([[1, 2, 3], [4, 5, 6]]))"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "flops.load('/tmp/123.npy')"
              },
              {
                "kind": "output",
                "text": "array([[1, 2, 3],"
              },
              {
                "kind": "output",
                "text": "       [4, 5, 6]])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Store compressed data to disk, and load it again:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a=flops.array([[1, 2, 3], [4, 5, 6]])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "b=flops.array([1, 2])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "flops.savez('/tmp/123.npz', a=a, b=b)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "data = flops.load('/tmp/123.npz')"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "data['a']"
              },
              {
                "kind": "output",
                "text": "array([[1, 2, 3],"
              },
              {
                "kind": "output",
                "text": "       [4, 5, 6]])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "data['b']"
              },
              {
                "kind": "output",
                "text": "array([1, 2])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "data.close()"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Mem-map the stored array, and then access the second row\ndirectly from disk:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "X = flops.load('/tmp/123.npy', mmap_mode='r')"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "X[1, :]"
              },
              {
                "kind": "output",
                "text": "memmap([4, 5, 6])"
              }
            ],
            "type": "doctest_block"
          }
        ],
        "title": "Examples"
