  "docs": {
    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Load arrays or pickled objects from "
              },
              {
                "kind": "code",
                "text": ".npy"
              },
              {
                "kind": "text",
                "text": ", "
              },
              {
                "kind": "code",
                "text": ".npz"
              },
              {
                "kind": "text",
                "text": " or pickled files."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "argument_inline": [
              {
                "kind": "text",
                "text": "Loading files that contain object arrays uses the "
              },
              {
                "kind": "code",
                "text": "pickle"
              }
            ],
            "content_blocks": [
              {
                "inline": [
                  {
                    "kind": "text",
                    "text": "module, which is not secure against erroneous or maliciously\nconstructed data. Consider passing "
                  },
                  {
                    "kind": "code",
                    "text": "allow_pickle=False"
                  },
                  {
                    "kind": "text",
                    "text": " to\nload data that is known not to contain object arrays for the\nsafer handling of untrusted sources."
                  }
                ],
                "type": "paragraph"
              }
            ],
            "directive": "warning",
            "options": [],
            "raw_source": ".. warning:: Loading files that contain object arrays uses the ``pickle``\n             module, which is not secure against erroneous or maliciously\n             constructed data. Consider passing ``allow_pickle=False`` to\n             load data that is known not to contain object arrays for the\n             safer handling of untrusted sources.",
            "supported": true,
            "type": "directive_block"
          }
        ],
        "title": "Extended Summary"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "The file to read. File-like objects must support the\n"
                      },
                      {
                        "kind": "code",
                        "text": "seek()"
                      },
                      {
                        "kind": "text",
                        "text": " and "
                      },
                      {
                        "kind": "code",
                        "text": "read()"
                      },
                      {
                        "kind": "text",
                        "text": " methods and must always\nbe opened in binary mode.  Pickled files require that the\nfile-like object support the "
                      },
                      {
                        "kind": "code",
                        "text": "readline()"
                      },
                      {
                        "kind": "text",
                        "text": " method as well."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "file-like object, string, or pathlib.Path",
                "inline": [
                  {
                    "kind": "text",
                    "text": "The file to read. File-like objects must support the\n"
                  },
                  {
                    "kind": "code",
                    "text": "seek()"
                  },
                  {
                    "kind": "text",
                    "text": " and "
                  },
                  {
                    "kind": "code",
                    "text": "read()"
                  },
                  {
                    "kind": "text",
                    "text": " methods and must always\nbe opened in binary mode.  Pickled files require that the\nfile-like object support the "
                  },
                  {
                    "kind": "code",
                    "text": "readline()"
                  },
                  {
                    "kind": "text",
                    "text": " method as well."
                  }
                ],
                "name": "file",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "If not None, then memory-map the file, using the given mode (see\n"
                      },
                      {
                        "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.memmap.html",
                        "href": "",
                        "kind": "link",
                        "target": "memmap",
                        "text": "flops.memmap"
                      },
                      {
                        "kind": "text",
                        "text": " for a detailed description of the modes).  A\nmemory-mapped array is kept on disk. However, it can be accessed\nand sliced like any ndarray.  Memory mapping is especially useful\nfor accessing small fragments of large files without reading the\nentire file into memory."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "{None, 'r+', 'r', 'w+', 'c'}, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "If not None, then memory-map the file, using the given mode (see\n"
                  },
                  {
                    "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.memmap.html",
                    "href": "",
                    "kind": "link",
                    "target": "memmap",
                    "text": "flops.memmap"
                  },
                  {
                    "kind": "text",
                    "text": " for a detailed description of the modes).  A\nmemory-mapped array is kept on disk. However, it can be accessed\nand sliced like any ndarray.  Memory mapping is especially useful\nfor accessing small fragments of large files without reading the\nentire file into memory."
                  }
                ],
                "name": "mmap_mode",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Allow loading pickled object arrays stored in npy files. Reasons for\ndisallowing pickles include security, as loading pickled data can\nexecute arbitrary code. If pickles are disallowed, loading object\narrays will fail. Default: False"
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "bool, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Allow loading pickled object arrays stored in npy files. Reasons for\ndisallowing pickles include security, as loading pickled data can\nexecute arbitrary code. If pickles are disallowed, loading object\narrays will fail. Default: False"
                  }
                ],
                "name": "allow_pickle",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Only useful when loading Python 2 generated pickled files on Python 3,\nwhich includes npy/npz files containing object arrays. If "
                      },
                      {
                        "kind": "code",
                        "text": "fix_imports"
                      },
                      {
                        "kind": "text",
                        "text": "\nis True, pickle will try to map the old Python 2 names to the new names\nused in Python 3."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "bool, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Only useful when loading Python 2 generated pickled files on Python 3,\nwhich includes npy/npz files containing object arrays. If "
                  },
                  {
                    "kind": "code",
                    "text": "fix_imports"
                  },
                  {
                    "kind": "text",
                    "text": "\nis True, pickle will try to map the old Python 2 names to the new names\nused in Python 3."
                  }
                ],
                "name": "fix_imports",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "What encoding to use when reading Python 2 strings. Only useful when\nloading Python 2 generated pickled files in Python 3, which includes\nnpy/npz files containing object arrays. Values other than 'latin1',\n'ASCII', and 'bytes' are not allowed, as they can corrupt numerical\ndata. Default: 'ASCII'"
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "str, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "What encoding to use when reading Python 2 strings. Only useful when\nloading Python 2 generated pickled files in Python 3, which includes\nnpy/npz files containing object arrays. Values other than 'latin1',\n'ASCII', and 'bytes' are not allowed, as they can corrupt numerical\ndata. Default: 'ASCII'"
                  }
                ],
                "name": "encoding",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Maximum allowed size of the header.  Large headers may not be safe\nto load securely and thus require explicitly passing a larger value.\nSee "
                      },
                      {
                        "display_text": "ast.literal_eval()",
                        "explicit_title": false,
                        "external_url": "",
                        "href": "",
                        "kind": "role_reference",
                        "original_target": "ast.literal_eval()",
                        "role": "py:func",
                        "suppress_link": false,
                        "target": "ast.literal_eval()",
                        "unresolved": true
                      },
                      {
                        "kind": "text",
                        "text": " for details.\nThis option is ignored when "
                      },
                      {
                        "kind": "code",
                        "text": "allow_pickle"
                      },
                      {
                        "kind": "text",
                        "text": " is passed.  In that case\nthe file is by definition trusted and the limit is unnecessary."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "int, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Maximum allowed size of the header.  Large headers may not be safe\nto load securely and thus require explicitly passing a larger value.\nSee "
                  },
                  {
                    "display_text": "ast.literal_eval()",
                    "explicit_title": false,
                    "external_url": "",
                    "href": "",
                    "kind": "role_reference",
                    "original_target": "ast.literal_eval()",
                    "role": "py:func",
                    "suppress_link": false,
                    "target": "ast.literal_eval()",
                    "unresolved": true
                  },
                  {
                    "kind": "text",
                    "text": " for details.\nThis option is ignored when "
                  },
                  {
                    "kind": "code",
                    "text": "allow_pickle"
                  },
                  {
                    "kind": "text",
                    "text": " is passed.  In that case\nthe file is by definition trusted and the limit is unnecessary."
                  }
                ],
                "name": "max_header_size",
                "type": "field_list"
              }
            ],
