      },
      {
        "blocks": [
          {
            "items": [
              {
                "blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "If the file contains pickle data, then whatever object is stored\nin the pickle is returned."
                      }
                    ],
                    "type": "paragraph"
                  }
                ]
              },
              {
                "blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "If the file is a "
                      },
                      {
                        "kind": "code",
                        "text": ".npy"
                      },
                      {
                        "kind": "text",
                        "text": " file, then a single array is returned."
                      }
                    ],
                    "type": "paragraph"
                  }
                ]
              },
              {
                "blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "If the file is a "
                      },
                      {
                        "kind": "code",
                        "text": ".npz"
                      },
                      {
                        "kind": "text",
                        "text": " file, then a dictionary-like object is\nreturned, containing "
                      },
                      {
                        "kind": "code",
                        "text": "{filename: array}"
                      },
                      {
                        "kind": "text",
                        "text": " key-value pairs, one for\neach file in the archive."
                      }
                    ],
                    "type": "paragraph"
                  }
                ]
              },
              {
                "blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "If the file is a "
                      },
                      {
                        "kind": "code",
                        "text": ".npz"
                      },
                      {
                        "kind": "text",
                        "text": " file, the returned value supports the\ncontext manager protocol in a similar fashion to the open function:"
                      }
                    ],
                    "type": "paragraph"
                  },
                  {
                    "language": null,
                    "text": "with load('foo.npz') as data:\n    a = data['a']",
                    "type": "literal_block"
                  },
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "The underlying file descriptor is closed when exiting the 'with'\nblock."
                      }
                    ],
                    "type": "paragraph"
                  }
                ]
              }
            ],
            "ordered": false,
            "type": "list"
          }
        ],
        "title": "Notes"
