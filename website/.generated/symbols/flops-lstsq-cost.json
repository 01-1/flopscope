    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "This helper multiplies the analytical FLOP count by the active weight from "
            },
            {
              "external_url": "https://numpy.org/doc/stable/reference/generated/numpy._weights.html",
              "href": "",
              "kind": "link",
              "target": "_weights",
              "text": "flopscope._weights"
            },
            {
              "kind": "text",
              "text": " and then applies "
            },
            {
              "kind": "code",
              "text": "int(...)"
            },
            {
              "kind": "text",
              "text": " so public estimates match budget deductions."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "NumPy uses LAPACK "
            },
            {
              "kind": "code",
              "text": "gelsd"
            },
            {
              "kind": "text",
              "text": " (SVD-based). Cost decomposition:\n"
            },
            {
              "kind": "code",
              "text": "svd(m,n) + ut_b + k*c + reconstruction"
            },
            {
              "kind": "text",
              "text": " where "
            },
            {
              "kind": "code",
              "text": "k = min(m, n)"
            },
            {
              "kind": "text",
              "text": "\nand "
            },
            {
              "kind": "code",
              "text": "c = b_cols"
            },
            {
              "kind": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "When "
            },
            {
              "kind": "code",
              "text": "b_ndim == 1"
            },
            {
              "kind": "text",
              "text": " (1D RHS), the intermediate matmuls are 2D\u00d71D\n(NumPy dispatches "
            },
            {
              "kind": "code",
              "text": "(k,m)@(m,)"
            },
            {
              "kind": "text",
              "text": " differently from "
            },
            {
              "kind": "code",
              "text": "(k,m)@(m,c)"
            },
            {
              "kind": "text",
              "text": "):\n"
            },
            {
              "kind": "code",
              "text": "ut_b = k * m * m"
            },
            {
              "kind": "text",
              "text": " and "
            },
            {
              "kind": "code",
              "text": "reconstruction = n * k * k"
            },
            {
              "kind": "text",
              "text": ".\nWhen "
            },
            {
              "kind": "code",
              "text": "b_ndim == 2"
            },
            {
              "kind": "text",
              "text": " (2D RHS), both are standard 2D\u00d72D matmuls:\n"
            },
            {
              "kind": "code",
              "text": "ut_b = matmul_cost(k, m, c)"
            },
            {
              "kind": "text",
              "text": " and "
            },
            {
              "kind": "code",
              "text": "reconstruction = matmul_cost(n, k, c)"
            },
            {
              "kind": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Issue #69 (was previously just "
            },
            {
              "kind": "code",
              "text": "svd_cost"
            },
            {
              "kind": "text",
              "text": " ignoring the\nback-substitution)."
            }
          ],
          "type": "paragraph"
        }
      ],
