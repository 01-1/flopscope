    {
      "blocks": [
        {
          "inline": [
            {
              "external_url": "",
              "href": "/docs/api/symmetrize/",
              "kind": "link",
              "target": "symmetrize",
              "text": "symmetrize"
            },
            {
              "kind": "text",
              "text": " performs exact Reynolds averaging internally, billing\n"
            },
            {
              "kind": "code",
              "text": "(|G| + 1) * numel(data)"
            },
            {
              "kind": "text",
              "text": " FLOPs:"
            }
          ],
          "type": "paragraph"
        },
        {
          "items": [
            {
              "blocks": [
                {
                  "inline": [
                    {
                      "kind": "code",
                      "text": "|G|"
                    },
                    {
                      "kind": "text",
                      "text": " transposed add passes over "
                    },
                    {
                      "kind": "code",
                      "text": "numel"
                    },
                    {
                      "kind": "text",
                      "text": " elements"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            },
            {
              "blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "one final scaling pass (divide by "
                    },
                    {
                      "kind": "code",
                      "text": "|G|"
                    },
                    {
                      "kind": "text",
                      "text": ")"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          ],
          "ordered": false,
          "type": "list"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Internal validation runs but is NOT billed (decision D1)."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "where "
            },
            {
              "kind": "code",
              "text": "|G|"
            },
            {
              "kind": "text",
              "text": " is the group order and "
            },
            {
              "kind": "code",
              "text": "numel = data.size"
            },
            {
              "kind": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "The canonical pattern for generating random data with symmetry is:"
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "code",
              "text": "fnp.random.symmetric(shape, symmetry_group, distribution=...)"
            },
            {
              "kind": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        }
