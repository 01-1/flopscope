              "kind": "code",
              "text": "loc"
            },
            {
              "kind": "text",
              "text": " is the location parameter and "
            },
            {
              "kind": "code",
              "text": "scale"
            },
            {
              "kind": "text",
              "text": " is the half-width at\nhalf-maximum. pdf deducts "
            },
            {
              "kind": "code",
              "text": "6 * numel(input)"
            },
            {
              "kind": "text",
              "text": " FLOPs (pure-arithmetic\ncomposite: z=(x-loc)/scale; 1/(pi*scale*(1+z^2)) = sub+div+mul+add+mul+div\n= 6 FLOPs/elem, weight 1.0; calibrated alpha 6.0). cdf deducts\n"
            },
            {
              "kind": "code",
              "text": "20 * numel(input)"
            },
            {
              "kind": "text",
              "text": " FLOPs (composite: z(2) + arctan(16) + /pi(1) +\n0.5+(1), FMA=2, weight 1.0). ppf deducts "
            },
            {
              "kind": "code",
              "text": "28 * numel(input)"
            },
            {
              "kind": "text",
              "text": " FLOPs\n(composite: q-0.5(1) + pi*(1) + tan(16) + loc+scale*(2) + 3 where(8),\nFMA=2, weight 1.0)."
            }
          ],
          "type": "paragraph"
        }
      ],
