    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "This helper multiplies the analytical FLOP count by the active weight from "
            },
            {
              "external_url": "https://numpy.org/doc/stable/reference/generated/numpy._weights.html",
              "href": "",
              "kind": "link",
              "target": "_weights",
              "text": "flopscope._weights"
            },
            {
              "kind": "text",
              "text": " and then applies "
            },
            {
              "kind": "code",
              "text": "int(...)"
            },
            {
              "kind": "text",
              "text": " so public estimates match budget deductions."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "NumPy implements "
            },
            {
              "kind": "code",
              "text": "pinv"
            },
            {
              "kind": "text",
              "text": " as: "
            },
            {
              "kind": "code",
              "text": "svd(A, full_matrices=False)"
            },
            {
              "kind": "text",
              "text": " \u2192\nthreshold tiny singular values \u2192 multiply "
            },
            {
              "kind": "code",
              "text": "vt.T"
            },
            {
              "kind": "text",
              "text": " by "
            },
            {
              "kind": "code",
              "text": "s_inv"
            },
            {
              "kind": "text",
              "text": "\nbroadcasted \u2192 matmul with "
            },
            {
              "kind": "code",
              "text": "u.T"
            },
            {
              "kind": "text",
              "text": ". We compose the cost from\n"
            },
            {
              "kind": "code",
              "text": "svd_cost"
            },
            {
              "kind": "text",
              "text": " and "
            },
            {
              "kind": "code",
              "text": "matmul_cost"
            },
            {
              "kind": "text",
              "text": " so this formula tracks those\nhelpers automatically (issue #69; was previously missing the\npost-SVD reconstruction)."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Total: "
            },
            {
              "kind": "code",
              "text": "svd(m,n) + threshold(min(m,n)) + diag_scale(n*min(m,n))\n+ matmul(n, min(m,n), m)"
            },
            {
              "kind": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "The SVD term uses with_vectors=True (the reconstruction needs U/V); the\n4.0 linalg weight is gone, so this composed value is exactly what is charged."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Notes"
    }
  ],
