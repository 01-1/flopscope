    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "This helper multiplies the analytical FLOP count by the active weight from "
            },
            {
              "external_url": "https://numpy.org/doc/stable/reference/generated/numpy._weights.html",
              "href": "",
              "kind": "link",
              "target": "_weights",
              "text": "flopscope._weights"
            },
            {
              "kind": "text",
              "text": " and then applies "
            },
            {
              "kind": "code",
              "text": "int(...)"
            },
            {
              "kind": "text",
              "text": " so public estimates match budget deductions."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "NumPy's unwrap ("
            },
            {
              "kind": "code",
              "text": "flops.lib._function_base_impl.unwrap"
            },
            {
              "kind": "text",
              "text": ") performs 13\none-FLOP ufunc passes over the N-1 element "
            },
            {
              "kind": "code",
              "text": "dd = diff(p)"
            },
            {
              "kind": "text",
              "text": " array, then\none final add of the cumulative correction into the output.  Counting\neach named ufunc call as one pass:"
            }
          ],
          "type": "paragraph"
        },
        {
          "items": [
            {
              "blocks": [
                {
                  "inline": [
                    {
                      "external_url": "",
                      "href": "/docs/api/numpy/diff/",
                      "kind": "link",
                      "target": "diff",
                      "text": "diff"
                    },
                    {
                      "kind": "text",
                      "text": "            \u2014 subtract adjacent elements (N-1 elements)"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            },
            {
              "blocks": [
                {
                  "inline": [
                    {
                      "kind": "code",
                      "text": "dd - low"
                    },
                    {
                      "kind": "text",
                      "text": "        \u2014 subtract scalar "
                    },
                    {
                      "kind": "code",
                      "text": "interval_low"
                    },
                    {
                      "kind": "text",
                      "text": " from dd"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            },
            {
              "blocks": [
                {
                  "inline": [
                    {
                      "kind": "code",
                      "text": "mod(..., period)"
                    },
                    {
                      "kind": "text",
                      "text": "\u2014 elementwise modulo"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            },
            {
              "blocks": [
                {
                  "inline": [
                    {
                      "kind": "code",
                      "text": "+ interval_low"
                    },
                    {
                      "kind": "text",
                      "text": "  \u2014 add scalar back"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            },
            {
              "blocks": [
                {
                  "inline": [
                    {
                      "kind": "code",
                      "text": "ddmod == low"
                    },
                    {
                      "kind": "text",
                      "text": "    \u2014 elementwise compare (boundary check)"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            },
            {
              "blocks": [
                {
                  "inline": [
                    {
                      "kind": "code",
                      "text": "dd > 0"
                    },
                    {
                      "kind": "text",
                      "text": "          \u2014 elementwise compare"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            },
            {
              "blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "``"
                    },
                    {
                      "kind": "text",
                      "text": "& ``              \u2014 bitwise-and of two bool arrays"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "raw_kind": "system_message",
                  "raw_text": "<string>:14: (WARNING/2) Inline literal start-string without end-string.",
                  "type": "raw_block"
                }
              ]
            },
            {
              "blocks": [
                {
                  "inline": [
                    {
                      "kind": "code",
                      "text": "copyto/select"
                    },
                    {
                      "kind": "text",
                      "text": "   \u2014 conditional write (boundary fix) "
                    },
                    {
                      "kind": "strong",
                      "text": "FREE"
                    },
                    {
                      "kind": "text",
                      "text": " (3-arg where)"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            },
            {
              "blocks": [
                {
                  "inline": [
                    {
                      "kind": "code",
                      "text": "ddmod - dd"
                    },
                    {
                      "kind": "text",
                      "text": "      \u2014 elementwise subtract (ph_correct)"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            },
            {
              "blocks": [
                {
                  "inline": [
                    {
                      "kind": "code",
                      "text": "abs(dd)"
                    },
                    {
                      "kind": "text",
                      "text": "         \u2014 elementwise absolute value"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            },
            {
              "blocks": [
                {
                  "inline": [
                    {
                      "kind": "code",
                      "text": "< discont"
                    },
                    {
                      "kind": "text",
                      "text": "       \u2014 elementwise compare"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            },
            {
              "blocks": [
                {
                  "inline": [
                    {
                      "kind": "code",
                      "text": "copyto/select"
                    },
                    {
                      "kind": "text",
                      "text": "   \u2014 conditional write (small-jump zeroing) "
                    },
                    {
                      "kind": "strong",
                      "text": "FREE"
                    },
                    {
                      "kind": "text",
                      "text": " (3-arg where)"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            },
            {
              "blocks": [
                {
                  "inline": [
                    {
                      "external_url": "",
                      "href": "/docs/api/numpy/cumsum/",
                      "kind": "link",
                      "target": "cumsum",
                      "text": "cumsum"
                    },
                    {
                      "kind": "text",
                      "text": "          \u2014 prefix-sum scan"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          ],
          "ordered": true,
          "type": "list"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "The "
            },
            {
              "kind": "code",
              "text": "p[slice1] + ph_correct.cumsum(axis)"
            },
            {
              "kind": "text",
              "text": " expression (final output\nmaterialization) involves one add pass but is treated as part of the\noutput-write cost \u2014 following the convention that the output buffer\nfill is attributed to the issuing op.  Charging all 11 "
            },
            {
              "kind": "emphasis",
              "text": "non-free"
            },
            {
              "kind": "text",
              "text": " op-passes\nagainst "
            },
            {
              "kind": "code",
              "text": "numel(input)"
            },
            {
              "kind": "text",
              "text": " rather than "
            },
            {
              "kind": "code",
              "text": "N-1"
            },
            {
              "kind": "text",
              "text": " avoids tracking the\nedge-element correction (one extra element) and gives a clean formula."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Steps 8 and 12 ("
            },
            {
              "kind": "code",
              "text": "copyto/select"
            },
            {
              "kind": "text",
              "text": " via 3-arg "
            },
            {
              "external_url": "",
              "href": "/docs/api/numpy/where/",
              "kind": "link",
              "target": "where",
              "text": "where"
            },
            {
              "kind": "text",
              "text": ") are pure data\nmovement (selecting by a given mask) and are therefore free per the\ncost-model rule introduced with the where-arity branching (Task 4,\n2026-06-15).  Prior value was "
            },
            {
              "kind": "code",
              "text": "13 * numel"
            },
            {
              "kind": "text",
              "text": " (included 2 free selects);\nbefore that it was "
            },
            {
              "kind": "code",
              "text": "7 * numel"
            },
            {
              "kind": "text",
              "text": " (Audit-completion Task 4, 2026-06-12)."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Notes"
    }
  ],
