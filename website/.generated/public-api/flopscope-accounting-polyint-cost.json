      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "numpy recurses m times; pass j divides n+j coefficients, so total cost\n= sum_{j=0}^{m-1} (n+j) = m*n + m*(m-1)//2."
            }
          ],
          "type": "paragraph"
        }
      ],
