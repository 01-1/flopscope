          "inline": [
            {
              "kind": "text",
              "text": "This helper multiplies the analytical FLOP count by the active weight from "
            },
            {
              "external_url": "https://numpy.org/doc/stable/reference/generated/numpy._weights.html",
              "href": "",
              "kind": "link",
              "target": "_weights",
              "text": "flopscope._weights"
            },
            {
              "kind": "text",
              "text": " and then applies "
            },
            {
              "kind": "code",
              "text": "int(...)"
            },
            {
              "kind": "text",
              "text": " so public estimates match budget deductions."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Uses exponentiation by repeated squaring. For "
            },
            {
              "kind": "code",
              "text": "k < 0"
            },
            {
              "kind": "text",
              "text": ", adds\n"
            },
            {
              "kind": "code",
              "text": "matmul_cost(n, n, n)"
            },
            {
              "kind": "text",
              "text": " for the initial matrix inversion (LU-based).\nPer-matmul cost is delegated to "
            },
            {
              "kind": "code",
              "text": "matmul_cost(n, n, n)"
            },
            {
              "kind": "text",
              "text": " so this formula\ntracks "
            },
            {
              "external_url": "",
              "href": "/docs/api/numpy/matmul/",
              "kind": "link",
              "target": "flopscope.numpy.matmul",
              "text": "fnp.matmul"
            },
            {
              "kind": "text",
              "text": "'s convention automatically (issue #69; the FMA=2\nunification of 2026-05-20 previously left this wrapper undercounting\nby ~2x)."
            }
          ],
          "type": "paragraph"
        }
      ],
