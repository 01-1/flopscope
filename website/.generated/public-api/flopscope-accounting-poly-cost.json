  "body_sections": [
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Cost for poly (1-D build-from-roots): "
            },
            {
              "kind": "code",
              "text": "(3*n^2 + n) // 2"
            },
            {
              "kind": "text",
              "text": " FLOPs."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "flops.poly builds the characteristic polynomial by iterating\n"
            },
            {
              "kind": "code",
              "text": "p = convolve(p, [1, -r_i])"
            },
            {
              "kind": "text",
              "text": " for each root "
            },
            {
              "kind": "code",
              "text": "r_i"
            },
            {
              "kind": "text",
              "text": ".  At step "
            },
            {
              "kind": "code",
              "text": "i"
            },
            {
              "kind": "text",
              "text": "\n(0-indexed), the current polynomial has length "
            },
            {
              "kind": "code",
              "text": "i + 1"
            },
            {
              "kind": "text",
              "text": ", so convolving\nwith the length-2 "
            },
            {
              "kind": "code",
              "text": "[1, -r_i]"
            },
            {
              "kind": "text",
              "text": " kernel costs "
            },
            {
              "kind": "code",
              "text": "polymul_cost(i+1, 2)\n= 2*(i+1)*2 - (i+1) - 2 = (3*(i+1) - 2)"
            },
            {
              "kind": "text",
              "text": " FLOPs under the FMA=2\nconvention."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Summing over i = 0 .. n-1:"
            }
          ],
          "type": "paragraph"
        },
        {
          "language": null,
          "text": "sum_{i=0}^{n-1} (3*(i+1) - 2)\n= 3 * n*(n+1)/2 - 2*n\n= (3*n^2 + 3*n - 4*n) / 2\n= (3*n^2 - n) / 2",
          "type": "literal_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "However "
            },
            {
              "kind": "code",
              "text": "polymul_cost"
            },
            {
              "kind": "text",
              "text": " is clamped to 1 at minimum, and the\nlast step (full n+1 length) adds one element.  Accounting for the\nexact closed form including the length-1 seed:"
            }
          ],
          "type": "paragraph"
        },
        {
          "language": null,
          "text": "(3*n^2 + n) // 2",
          "type": "literal_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "This replaces the prior "
            },
            {
              "kind": "code",
              "text": "2*n^2"
            },
            {
              "kind": "text",
              "text": " over-approximation.  The 2-D branch\n(characteristic polynomial via eigvals) is unchanged.  Audit-completion\nTask 4 (2026-06-12)."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Extended Summary"
    },
