              "kind": "text",
              "text": "Update flopscope global settings."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "items": [
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "If "
                    },
                    {
                      "kind": "code",
                      "text": "True"
                    },
                    {
                      "kind": "text",
                      "text": ", scan every counted op's output for NaN/Inf values and\nemit a "
                    },
                    {
                      "display_text": "FlopscopeWarning",
                      "explicit_title": false,
                      "external_url": "",
                      "href": "",
                      "kind": "role_reference",
                      "original_target": "flopscope.errors.FlopscopeWarning",
                      "role": "class",
                      "suppress_link": false,
                      "target": "errors.FlopscopeWarning",
                      "unresolved": true
                    },
                    {
                      "kind": "text",
                      "text": " if any are found.\nThe scan is two full O(n) sweeps over the result and is attributed\nto "
                    },
                    {
                      "kind": "code",
                      "text": "flopscope_overhead_time"
                    },
                    {
                      "kind": "text",
                      "text": ", so it is off by default for\nproduction scoring.  Opt in when debugging an estimator that\nproduces NaN/Inf to identify the introducing op.  Default "
                    },
                    {
                      "kind": "code",
                      "text": "False"
                    },
                    {
                      "kind": "text",
                      "text": "."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "bool",
              "inline": [
