            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Maximum number of group elements during whole-expression G_pt closure.\nPathological declared-symmetry cases that exceed this budget fall back\nto dense cost with a CostFallbackWarning.  Default "
                    },
                    {
                      "kind": "code",
                      "text": "500_000"
                    },
                    {
                      "kind": "text",
                      "text": "."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "int",
              "inline": [
                {
                  "kind": "text",
                  "text": "Maximum number of group elements during whole-expression G_pt closure.\nPathological declared-symmetry cases that exceed this budget fall back\nto dense cost with a CostFallbackWarning.  Default "
                },
                {
                  "kind": "code",
                  "text": "500_000"
                },
                {
                  "kind": "text",
                  "text": "."
                }
              ],
              "name": "dimino_budget",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Maximum number of entries in the einsum path cache.\nChanging this rebuilds the cache (old entries are discarded).\nDefault "
                    },
                    {
                      "kind": "code",
                      "text": "4096"
                    },
                    {
                      "kind": "text",
                      "text": "."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "int",
              "inline": [
                {
                  "kind": "text",
                  "text": "Maximum number of entries in the einsum path cache.\nChanging this rebuilds the cache (old entries are discarded).\nDefault "
                },
                {
                  "kind": "code",
                  "text": "4096"
                },
                {
                  "kind": "text",
                  "text": "."
                }
              ],
