              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Maximum number of typed partitions a single component may have before\nthe partitionCount regime refuses.  Components exceeding this budget\nfall back to the dense cost with a CostFallbackWarning.  Default\n"
                    },
                    {
                      "kind": "code",
                      "text": "100_000"
                    },
                    {
                      "kind": "text",
                      "text": " (covers Bell(9)=21_147; Bell(10)=115_975 forces fallback).\nSet to "
                    },
                    {
                      "kind": "code",
                      "text": "0"
                    },
                    {
                      "kind": "text",
                      "text": " to force fallback for any non-trivial component."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "int",
              "inline": [
