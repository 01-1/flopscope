    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "This helper multiplies the analytical FLOP count by the active weight from "
            },
            {
              "external_url": "https://numpy.org/doc/stable/reference/generated/numpy._weights.html",
              "href": "",
              "kind": "link",
              "target": "_weights",
              "text": "flopscope._weights"
            },
            {
              "kind": "text",
              "text": " and then applies "
            },
            {
              "kind": "code",
              "text": "int(...)"
            },
            {
              "kind": "text",
              "text": " so public estimates match budget deductions."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "NumPy uses LAPACK "
            },
            {
              "kind": "code",
              "text": "gelsd"
            },
            {
              "kind": "text",
              "text": " (SVD-based). Cost decomposition:\n"
            },
            {
              "kind": "code",
              "text": "svd(m,n) + ut_b + k*c + reconstruction"
            },
            {
              "kind": "text",
              "text": " where "
            },
            {
              "kind": "code",
              "text": "k = min(m, n)"
            },
            {
              "kind": "text",
              "text": "\nand "
            },
            {
              "kind": "code",
              "text": "c = b_cols"
            },
            {
              "kind": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Both 1-D and 2-D RHS branches use "
            },
            {
              "kind": "code",
              "text": "matmul_cost"
            },
            {
              "kind": "text",
              "text": ":\n"
            },
            {
              "kind": "code",
              "text": "ut_b = matmul_cost(k, m, b_cols)"
            },
            {
              "kind": "text",
              "text": " and\n"
            },
            {
              "kind": "code",
              "text": "reconstruction = matmul_cost(n, k, b_cols)"
            },
            {
              "kind": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Issue #69 (was previously just "
            },
            {
              "kind": "code",
              "text": "svd_cost"
            },
            {
              "kind": "text",
              "text": " ignoring the\nback-substitution)."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "The SVD term uses with_vectors=True (the reconstruction needs U/V); the\n4.0 linalg weight is gone, so this composed value is exactly what is charged."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Notes"
    }
