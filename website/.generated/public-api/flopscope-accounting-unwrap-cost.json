          "inline": [
            {
              "kind": "text",
              "text": "This helper multiplies the analytical FLOP count by the active weight from "
            },
            {
              "external_url": "https://numpy.org/doc/stable/reference/generated/numpy._weights.html",
              "href": "",
              "kind": "link",
              "target": "_weights",
              "text": "flopscope._weights"
            },
            {
              "kind": "text",
              "text": " and then applies "
            },
            {
              "kind": "code",
              "text": "int(...)"
            },
            {
              "kind": "text",
              "text": " so public estimates match budget deductions."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "NumPy's unwrap ("
            },
            {
              "kind": "code",
              "text": "flops.lib._function_base_impl.unwrap"
            },
            {
              "kind": "text",
              "text": ") does\napproximately 6 full-array ufunc passes: "
            },
            {
              "external_url": "",
              "href": "/docs/api/numpy/diff/",
              "kind": "link",
              "target": "diff",
              "text": "diff"
            },
            {
              "kind": "text",
              "text": ", "
            },
            {
              "external_url": "",
              "href": "/docs/api/numpy/mod/",
              "kind": "link",
              "target": "mod",
              "text": "mod"
            },
            {
              "kind": "text",
              "text": ", "
            },
            {
              "external_url": "",
              "href": "/docs/api/numpy/add/",
              "kind": "link",
              "target": "add",
              "text": "add"
            },
            {
              "kind": "text",
              "text": ",\n"
            },
            {
              "external_url": "",
              "href": "/docs/api/numpy/subtract/",
              "kind": "link",
              "target": "subtract",
              "text": "subtract"
            },
            {
              "kind": "text",
              "text": ", "
            },
            {
              "external_url": "",
              "href": "/docs/api/numpy/cumsum/",
              "kind": "link",
              "target": "cumsum",
              "text": "cumsum"
            },
            {
              "kind": "text",
              "text": ", and "
            },
            {
              "external_url": "",
              "href": "/docs/api/numpy/where/",
              "kind": "link",
              "target": "where",
              "text": "where"
            },
            {
              "kind": "text",
              "text": ". The "
            },
            {
              "external_url": "",
              "href": "/docs/api/numpy/where/",
              "kind": "link",
              "target": "where",
              "text": "where"
            },
            {
              "kind": "text",
              "text": " pass with two\nreal-array arguments charges 2*(N-1) elements rather than N-1,\nbringing the effective total to ~7*(N-1). We charge a fixed\n"
            },
            {
              "kind": "code",
              "text": "7 * numel"
            },
            {
              "kind": "text",
              "text": " to approximate the sum without tracking numpy's\ninternal implementation byte-by-byte. Issue #69."
            }
          ],
          "type": "paragraph"
        }
