    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "The "
            },
            {
              "kind": "code",
              "text": ".npz"
            },
            {
              "kind": "text",
              "text": " file format is a zipped archive of files named after the\nvariables they contain.  The archive is not compressed and each file\nin the archive contains one variable in "
            },
            {
              "kind": "code",
              "text": ".npy"
            },
            {
              "kind": "text",
              "text": " format. For a\ndescription of the "
            },
            {
              "kind": "code",
              "text": ".npy"
            },
            {
              "kind": "text",
              "text": " format, see "
            },
            {
              "display_text": "flops.lib.format",
              "explicit_title": false,
              "external_url": "",
              "href": "",
              "kind": "role_reference",
              "original_target": "flops.lib.format",
              "role": "py:mod",
              "suppress_link": false,
              "target": "lib.format",
              "unresolved": true
            },
            {
              "kind": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "When opening the saved "
            },
            {
              "kind": "code",
              "text": ".npz"
            },
            {
              "kind": "text",
              "text": " file with "
            },
            {
              "external_url": "",
              "href": "/docs/api/numpy/load/",
              "kind": "link",
              "target": "load",
              "text": "load"
            },
            {
              "kind": "text",
              "text": " a "
            },
            {
              "kind": "code",
              "text": "~lib.npyio.NpzFile"
            },
            {
              "kind": "text",
              "text": "\nobject is returned. This is a dictionary-like object which can be queried\nfor its list of arrays (with the "
            },
            {
              "kind": "code",
              "text": ".files"
            },
            {
              "kind": "text",
              "text": " attribute), and for the arrays\nthemselves."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Keys passed in "
            },
            {
              "kind": "code",
              "text": "kwds"
            },
            {
              "kind": "text",
              "text": " are used as filenames inside the ZIP archive.\nTherefore, keys should be valid filenames; e.g., avoid keys that begin with\n"
            },
            {
              "kind": "code",
              "text": "/"
            },
            {
              "kind": "text",
              "text": " or contain "
            },
            {
              "kind": "code",
              "text": "."
            },
            {
              "kind": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "When naming variables with keyword arguments, it is not possible to name a\nvariable "
            },
            {
              "kind": "code",
              "text": "file"
            },
            {
              "kind": "text",
              "text": ", as this would cause the "
            },
            {
              "kind": "code",
              "text": "file"
            },
            {
              "kind": "text",
              "text": " argument to be defined\ntwice in the call to "
            },
            {
              "external_url": "",
              "href": "/docs/api/numpy/savez/",
              "kind": "link",
              "target": "savez",
              "text": "savez"
            },
            {
              "kind": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        }
