  "body_sections": [
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Save several arrays into a single file in uncompressed "
            },
            {
              "kind": "code",
              "text": ".npz"
            },
            {
              "kind": "text",
              "text": " format."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Provide arrays as keyword arguments to store them under the\ncorresponding name in the output file: "
            },
            {
              "kind": "code",
              "text": "savez(fn, x=x, y=y)"
            },
            {
              "kind": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "If arrays are specified as positional arguments, i.e., "
            },
            {
              "kind": "code",
              "text": "savez(fn,\nx, y)"
            },
            {
              "kind": "text",
              "text": ", their names will be "
            },
            {
              "kind": "code",
              "text": "arr_0"
            },
            {
              "kind": "text",
              "text": ", "
            },
            {
              "kind": "code",
              "text": "arr_1"
            },
            {
              "kind": "text",
              "text": ", etc."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Extended Summary"
    },
    {
      "blocks": [
        {
          "items": [
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Either the filename (string) or an open file (file-like object)\nwhere the data will be saved. If file is a string or a Path, the\n"
                    },
                    {
                      "kind": "code",
                      "text": ".npz"
                    },
                    {
                      "kind": "text",
                      "text": " extension will be appended to the filename if it is not\nalready there."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "file, str, or pathlib.Path",
              "inline": [
                {
                  "kind": "text",
                  "text": "Either the filename (string) or an open file (file-like object)\nwhere the data will be saved. If file is a string or a Path, the\n"
                },
                {
                  "kind": "code",
                  "text": ".npz"
                },
                {
                  "kind": "text",
                  "text": " extension will be appended to the filename if it is not\nalready there."
                }
              ],
              "name": "file",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Arrays to save to the file. Please use keyword arguments (see\n"
                    },
                    {
                      "kind": "code",
                      "text": "kwds"
                    },
                    {
                      "kind": "text",
                      "text": " below) to assign names to arrays.  Arrays specified as\nargs will be named \"arr_0\", \"arr_1\", and so on."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "Arguments, optional",
              "inline": [
                {
                  "kind": "text",
                  "text": "Arrays to save to the file. Please use keyword arguments (see\n"
                },
                {
                  "kind": "code",
                  "text": "kwds"
                },
                {
                  "kind": "text",
                  "text": " below) to assign names to arrays.  Arrays specified as\nargs will be named \"arr_0\", \"arr_1\", and so on."
                }
              ],
              "name": "args",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Allow saving object arrays using Python pickles. Reasons for\ndisallowing pickles include security (loading pickled data can execute\narbitrary code) and portability (pickled objects may not be loadable\non different Python installations, for example if the stored objects\nrequire libraries that are not available, and not all pickled data is\ncompatible between different versions of Python).\nDefault: True"
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "bool, optional",
              "inline": [
                {
                  "kind": "text",
                  "text": "Allow saving object arrays using Python pickles. Reasons for\ndisallowing pickles include security (loading pickled data can execute\narbitrary code) and portability (pickled objects may not be loadable\non different Python installations, for example if the stored objects\nrequire libraries that are not available, and not all pickled data is\ncompatible between different versions of Python).\nDefault: True"
                }
              ],
              "name": "allow_pickle",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Arrays to save to the file. Each array will be saved to the\noutput file with its corresponding keyword name."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "Keyword arguments, optional",
              "inline": [
                {
                  "kind": "text",
                  "text": "Arrays to save to the file. Each array will be saved to the\noutput file with its corresponding keyword name."
                }
              ],
